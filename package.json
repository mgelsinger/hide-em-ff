{
  "name": "hide-em",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:options && npm run build:background && npm run build:content",
    "build:options": "vite build",
    "build:background": "ENTRY=background vite build -c vite.scripts.config.ts",
    "build:content": "ENTRY=content vite build -c vite.scripts.config.ts",
    "dev": "npm run build:background && npm run build:content && vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:web-ext": "web-ext lint --source-dir dist",
    "start:firefox": "web-ext run --source-dir dist --start-url about:debugging#/runtime/this-firefox",
    "package": "web-ext build --source-dir dist --artifacts-dir web-ext-artifacts --overwrite-dest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.11",
    "vitest": "^1.6.0",
    "web-ext": "^8.3.0"
  }
}
